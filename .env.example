# PostgreSQL database. Example from Neon/Supabase/Railway.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# A long random value. Generate with: openssl rand -base64 32
SESSION_SECRET="replace-with-a-long-random-secret"

# Steam Web API key from Steam Community Developer.
STEAM_API_KEY="replace-with-your-steam-web-api-key"

# Local: http://localhost:3000
# Production: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
